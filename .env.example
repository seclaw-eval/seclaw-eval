# SPECSYNTH-CLAWBENCH configuration
# Benchmark for evaluating AI agent safety in synthetic openclaw tasks.
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Optional PyPI mirror for fixture setup inside Docker containers.
# PIP_INDEX_URL=https://pypi.org/simple

# Model provider(s) under test for scripts/batch_execute.sh --backend docker.
# docker_models_config.yaml maps each model entry to one of these providers.
DOCKER_BACKEND_MODEL_ID=your-model-id
DOCKER_BACKEND_BASE_URL=https://api.provider-a.example.com/v1
DOCKER_BACKEND_API_KEY=your-model-api-key-here

# Optional second provider/model. Add _3, _4, ... variables as needed and
# reference them from additional docker_models_config.yaml entries.
DOCKER_BACKEND_MODEL_ID_2=your-second-model-id
DOCKER_BACKEND_BASE_URL_2=https://api.provider-b.example.com/v1
DOCKER_BACKEND_API_KEY_2=your-second-model-api-key-here

# Judge model provider(s) for LLM judge or multi-judge scoring.
EVAL_JUDGE_MODEL_ID=your-judge-model-id
EVAL_JUDGE_BASE_URL=https://api.judge-provider-a.example.com/v1
EVAL_JUDGE_API_KEY=your-judge-api-key-here

EVAL_JUDGE_MODEL_ID_2=your-second-judge-model-id
EVAL_JUDGE_BASE_URL_2=https://api.judge-provider-b.example.com/v1
EVAL_JUDGE_API_KEY_2=your-second-judge-api-key-here

# Simulated user agent for adaptive/user_agent_server multi-turn tasks.
USER_AGENT_MODEL_ID=your-user-agent-model-id
USER_AGENT_BASE_URL=https://api.user-agent-provider.example.com/v1
USER_AGENT_API_KEY=your-user-agent-api-key-here

# Optional analysis thresholds.
# BATCH_EVAL_LOW_SCORE_THRESHOLD=0.3
# BATCH_EVAL_HIGH_SCORE_THRESHOLD=0.8
# BATCH_EVAL_DIFF_THRESHOLD=0.3
